# Google Sheets API endpoint for live product data
# Use a sheet.best or SheetDB endpoint pointed at a Google Sheet with columns:
# id, productName, slug, category, subCategory, description, fullDescription,
# price, imageUrl, stockStatus, featured, origin, packaging, moq
#
# If unset, the app falls back to the static product data in src/data/products.ts
VITE_SHEETS_API_URL=
