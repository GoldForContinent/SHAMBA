# Google Sheets API endpoint for live product data
# Use a sheet.best or SheetDB endpoint pointed at a Google Sheet with columns:
# id, productName, slug, category, subCategory, description, fullDescription,
# price, imageUrl, stockStatus, featured, origin, packaging, moq,
# applications, specifications, qualityInfo, shippingInfo
#
# applications — semicolon-separated list (e.g. "Rope manufacturing; Twine production")
# descriptionAttributes — semicolon-separated key:value pairs (e.g. "Country of Origin: Kenya; Latin Name: Helianthus annuus")
# productDetails — semicolon-separated key:value pairs (e.g. "Ingredients: Crude sunflower oil; Process: Cold-pressed")
# nutritionalValues — semicolon-separated key:value pairs (e.g. "Energy (kJ): 3760 kJ; Fat: 9 g; Protein: 0 g")
#
# If unset, the app falls back to the static product data in src/data/products.ts
VITE_SHEETS_API_URL=https://api.sheetbest.com/sheets/dfd898fd-9968-427d-bee7-a0e20fbf0fcb
